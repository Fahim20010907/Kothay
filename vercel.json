{
    "version": 2,
    "builds": [
        {
            "src": "kothay-client/**",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/kothay-client/dist/$1"
        }
    ]
}